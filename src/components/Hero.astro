<script>
    function fitFontSize(text: string, maxWidth: number, family = "Name Sans") {
        const ctx = document.createElement("canvas").getContext("2d");
        if (!ctx) return 16;
        let lo = 1,
            hi = 1000;
        while (hi - lo > 0.5) {
            const mid = (lo + hi) / 2;
            ctx.font = `${mid}px ${family}`;
            ctx.measureText(text).width < maxWidth ? (lo = mid) : (hi = mid);
        }
        return lo;
    }

    const els = document.querySelectorAll(
        ".hero-header",
    ) as NodeListOf<HTMLHeadingElement>;
    els.forEach((el) => {
        if (!el.parentElement) return;
        window.addEventListener("resize", () => {
            if (!el.parentElement) return;
            el.style.fontSize =
                Math.round(
                    fitFontSize(
                        el.textContent.trim(),
                        el.parentElement.clientWidth - 96,
                    ),
                ) + "px";
        });
        el.style.fontSize =
            Math.round(
                fitFontSize(
                    el.textContent.trim(),
                    el.parentElement.clientWidth - 96,
                ),
            ) + "px";
    });
</script>
<script>
    import gsap from "gsap";
    import { GSDevTools } from "gsap/GSDevTools";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(GSDevTools, SplitText);

    // GSDevTools.create();

    const tl = gsap.timeline();
    const portSplit = new SplitText(".port-split", { type: "chars" });
    const folioSplit = new SplitText(".folio-split", { type: "chars" });

    tl.set(".intro-bg", {
        transformOrigin: "center",
        top: "50%",
        left: "50%",
        translate: "-50% -50%",
    })
        .set(".grid-els > *", {
            y: "-200%",
        })
        .to(".intro-bg", {
            scale: 1,
            ease: "power2.out",
            duration: 0.5,
            borderRadius: "100%",
        })
        .to(
            ".intro-bg",
            {
                ease: "power2.out",
                duration: 0.5,
                borderRadius: "0",
            },
            ">1",
        )
        .to(".intro-bg", {
            ease: "power2.out",
            duration: 1,
            width: "100%",
        })
        .to(
            ".intro-bg",
            {
                ease: "power2.inOut",
                duration: 2,
                height: "100%",
            },
            "intro-complete",
        )
        .set(".intro-bg", {
            bottom: 0,
            top: "auto",
            translate: "-50% 0",
        })
        .set(".actual-title", { opacity: 1 })
        .to(".intro-bg", {
            transformOrigin: "bottom",
        });

    tl.set(".port-split", { top: 0, left: 0 }, 0);
    tl.set(".folio-split", { bottom: 0, right: 0 }, 0);
    tl.set([portSplit.chars, folioSplit.chars], { y: "100%" }, 0);

    tl.to(
        [portSplit.chars, folioSplit.chars],
        {
            y: "0%",
            ease: "power2.out",
            duration: 0.75,
            stagger: 0.05,
        },
        "intro-complete+=1",
    );

    tl.to(".port-split", {
        top: "100%",
        transform: "translateY(-100%)",
        ease: "power2.in",
        left: 0,
        duration: 0.75,
    })

        .addLabel("text-animate-complete");

    tl.to(
        ".intro-bg",
        {
            height: 0,
            ease: "power2.in",
            duration: 0.75,
            bottom: 0,
        },
        "text-animate-complete-=0.75",
    )
        .to(
            ".title-clip",
            {
                height: 0,
                bottom: 0,
                ease: "power2.in",
                duration: 0.75,
            },
            "text-animate-complete-=0.75",
        )
        .to(
            ".title-clip",
            {
                padding: 0,
            },
            ">",
        )
        .addLabel("bg-swipe-complete");

    tl.to(
        ".grid-els > *",
        {
            y: 0,
            stagger: 0.2,
            ease: "power2.out",
            duration: 1,
        },
        "bg-swipe-complete+=0.25",
    );
</script>
