---
interface Props extends astroHTML.JSX.VideoHTMLAttributes {
    src: string;
    class?: string;
    style?: string;
}

const { src, class: className, style, ...props } = Astro.props;
const normalizedClassName = className
    ?.replace(/\bobject-(contain|cover)\b/g, "")
    .replace(/\s+/g, " ")
    .trim();
const videoClass = [
    "lg:opacity-0 opacity-100 object-contain",
    normalizedClassName,
]
    .filter(Boolean)
    .join(" ");
---

<video
    data-webgl-video
    src={src}
    class={videoClass}
    style={style}
    autoplay
    loop
    muted
    playsinline
    {...props}
>
    <source src={src} type="video/mp4" />
</video>
