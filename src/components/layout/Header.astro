---
import ThemeSwitcher from "../ThemeSwitcher.astro";
---

<nav
    class="w-full h-12 border-b border-border sticky top-0 z-20 flex justify-center items-center bg-background"
>
    <div class="w-5/6 md:w-3/4 lg:w-1/2 relative h-full">
        <div
            class="z-10 size-2 rotate-45 border-1 bg-background border-border absolute bottom-0 left-0 -translate-x-1/2 translate-y-1/2"
        >
        </div>
        <div
            class="w-auto h-full border-x border-border flex justify-between px-4 text-sm items-center font-departure-mono text-text-secondary"
        >
            <p><a href="/">WB</a></p>
            <ul class="*:inline *:pl-4 *:hover:opacity-75 *:transition-all">
                <li><a href="/#projects">Projects</a></li>
                <li><a href="/#writing">Writing</a></li>
                <li><ThemeSwitcher /></li>
            </ul>
        </div>
        <div
            class="z-10 size-2 rotate-45 border-1 bg-background border-border absolute bottom-0 right-0 translate-y-1/2 translate-x-1/2"
        >
        </div>
    </div>
    <div
        class="absolute top-12 w-5/6 md:w-3/4 lg:w-1/2 h-[40px] pointer-events-none blur-gradient-top"
    >
    </div>
</nav>
