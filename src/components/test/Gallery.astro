---
type ArrayElement<ArrayType extends readonly unknown[]> =
    ArrayType extends readonly (infer ElementType)[] ? ElementType : never;

interface Props {
    id: string;
    ratio: string | null;
    images: Array<{
        type: "img" | "vid";
        fit?: boolean;
        src: string;
        alt: string;
    }>;
}

const { id, ratio, images } = Astro.props;
---

<script define:vars={{ id }}>
    window.addEventListener("DOMContentLoaded", () => {
        const carousel = document.querySelector(`#${id}-carousel`);
        const prev = document.querySelector(`#${id}-prev`);
        const next = document.querySelector(`#${id}-next`);
        const wrapper = document.querySelector(`#${id}`);

        let hovered = false;
        let isMobile = window.innerWidth < 1024 ? true : false;

        if (!carousel || !prev || !next) return;

        const hide = (el) => {
            el.classList.add("opacity-0", "pointer-events-none");
            el.classList.remove("opacity-100", "pointer-events-auto");
        };

        const show = (el) => {
            el.classList.remove("opacity-0", "pointer-events-none");
            el.classList.add("opacity-100", "pointer-events-auto");
        };

        const updateButtons = () => {
            if (isMobile || hovered) {
                const scrollLeft = carousel.scrollLeft;
                const maxScrollLeft =
                    carousel.scrollWidth - carousel.clientWidth;

                if (scrollLeft <= 0) {
                    hide(prev);
                } else {
                    show(prev);
                }

                if (scrollLeft >= maxScrollLeft - 1) {
                    hide(next);
                } else {
                    show(next);
                }
            }
        };

        if (isMobile) updateButtons();

        prev.addEventListener("click", () => {
            carousel.scrollBy({
                left: -carousel.offsetWidth,
                behavior: "smooth",
            });
        });

        next.addEventListener("click", () => {
            carousel.scrollBy({
                left: carousel.offsetWidth,
                behavior: "smooth",
            });
        });

        carousel.addEventListener("scroll", updateButtons);

        wrapper.addEventListener("mouseover", () => {
            hovered = true;
            updateButtons();
        });

        wrapper.addEventListener("mouseleave", () => {
            hovered = false;
            if (isMobile) return;
            hide(prev);
            hide(next);
        });

        window.addEventListener("resize", () => {
            isMobile = window.innerWidth < 1024 ? true : false;
            updateButtons();
        });
    });
</script>

<div
    style={ratio ? `aspect-ratio: ${ratio}` : null}
    id={id}
    class="w-full mt-2 mb-8 relative"
>
    <button
        id={`${id}-prev`}
        aria-label="Previous"
        class="absolute left-4 top-1/2 -translate-y-1/2 z-10 bg-background p-2 duration-300 opacity-0 pointer-events-none roup-hover:opacity-100 group-hover:pointer-events-auto transition-all hover:cursor-pointer hover:text-text-primary ouch-manipulation"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="size-8"
        >
            <path
                fill-rule="evenodd"
                d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 -1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z"
                clip-rule="evenodd"></path>
        </svg>
    </button>
    <div
        id={`${id}-carousel`}
        style={ratio ? `aspect-ratio: ${ratio}` : null}
        class="w-full flex relative overflow-x-auto overflow-y-hidden snap-x snap-mandatory scrollbar-hide"
    >
        {
            images.map((img) => {
                return (
                    <div class="min-w-full flex-shrink-0 relative flex items-center justify-center bg-background snap-center">
                        {img.type === "img" ? (
                            <img
                                class={`${img.fit ? "object-contain h-full" : "object-cover w-full h-full"}`}
                                src={img.src}
                                alt={img.alt}
                            />
                        ) : (
                            <video
                                class="h-full object-cover"
                                autoplay
                                loop
                                muted
                                playsinline
                            >
                                <source src={img.src} type="video/mp4" />
                            </video>
                        )}
                        <p class="absolute bottom-0 right-0 bg-background text-xs text-text-secondary px-4 py-2 border border-border">
                            {img.alt}
                        </p>
                    </div>
                );
            })
        }
    </div>
    <button
        id={`${id}-next`}
        aria-label="Next"
        class="absolute right-4 top-1/2 -translate-y-1/2 z-10 bg-background p-2 duration-300 opacity-0 pointer-events-none roup-hover:opacity-100 group-hover:pointer-events-auto transition-all hover:cursor-pointer hover:text-text-primary ouch-manipulation"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
            fill="currentColor"
            class="size-8"
        >
            <path
                fill-rule="evenodd"
                d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 .25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
                clip-rule="evenodd"></path>
        </svg>
    </button>
</div>

<style>
    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }
</style>
