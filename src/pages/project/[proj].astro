---
import MainLayout from "../../layouts/MainLayout.astro";
import VerticalDivider from "../../components/VerticalDivider.astro";
import AnimatedDot from "../../components/AnimatedDot";
import ProjectGallery from "../../components/ProjectGallery.astro";
import ProjectInfo from "../../components/ProjectInfo.astro";

import { getCollection } from "astro:content";

// Get the slug from the URL params
export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => ({
        params: { proj: project.id.replace(/\.json$/, "") },
        props: { project },
    }));
}

const { project } = Astro.props;

import { formatDate } from "../../utils/date";
---

<MainLayout>
    <main class="w-5/6 md:w-3/4 lg:w-1/2 border-x border-border bg-background">
        <div class="px-4 py-8">
            <a
                href="/"
                class="text-sm text-text-secondary hover:opacity-75 transition-all font-departure-mono flex items-center gap-1"
            >
                <svg
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    class="size-4 inline mr-1"
                >
                    <path
                        d="M20 11v2H8v2H6v-2H4v-2h2V9h2v2h12zM10 7H8v2h2V7zm0 0h2V5h-2v2zm0 10H8v-2h2v2zm0 0h2v2h-2v-2z"
                        fill="currentColor"></path>
                </svg>
                Back to all projects
            </a>
        </div>
        <VerticalDivider />
        <article class="w-full">
            <VerticalDivider />
            <div class="w-full px-4 py-8">
                <p
                    class="w-full text-xs flex justify-between font-departure-mono text-text-secondary mb-4"
                >
                    <span class="lowercase">[{project.data.type}]</span>{" "}
                    <span class="uppercase">
                        {formatDate(project.data.year)}
                    </span>
                </p>
                <h2
                    class="text-4xl text-text-primary flex justify-between w-full"
                >
                    {project.data.title}
                </h2>
            </div>
            <div class="sticky top-12 w-full bg-background z-10">
                <VerticalDivider sticky />
                <div class="w-full p-4">
                    <h3
                        class="text-xl text-text-primary capitalize flex items-center gap-0.5"
                    >
                        <AnimatedDot client:load animateLayout={true} />
                        project outline
                    </h3>
                </div>
                <VerticalDivider sticky />
            </div>
            <div class="p-4">
                {
                    project.data.outline
                        .split("\n")
                        .map((para) => (
                            <p class="text-text-primary not-last:mb-4 leading-relaxed">
                                {para}
                            </p>
                        ))
                }
            </div>
        </article>

        {
            project.data.slideshows.map((slideshow) => (
                <>
                    <div class="sticky top-12 w-full z-10 bg-background">
                        <VerticalDivider sticky />
                        <div class="w-full p-4">
                            <h3 class="text-xl text-text-primary capitalize flex items-center gap-0.5">
                                <AnimatedDot client:load animateLayout={true} />
                                {slideshow.title}
                            </h3>
                        </div>
                        <VerticalDivider sticky />
                    </div>
                    <div>
                        <ProjectGallery
                            id={`${project.id}-${slideshow.title.split(" ").join("-").toLowerCase().replace(":", "")}`}
                            images={slideshow.images}
                            ratio={slideshow.ratio ?? null}
                        />
                    </div>
                </>
            ))
        }

        <div class="sticky top-12 w-full bg-background z-10">
            <VerticalDivider sticky />
            <div class="w-full p-4">
                <h2 class="text-xl text-text-primary flex items-center gap-0.5">
                    <AnimatedDot client:load animateLayout={true} />More Info
                </h2>
            </div>
            <VerticalDivider sticky />
        </div>
        <div class="w-full px-4 py-8">
            <ProjectInfo project={project.data} />
        </div>
        <VerticalDivider />
        <div class="h-[60vh]"></div>
        <VerticalDivider />
    </main>
    <!-- <VerticalDivider /> -->
</MainLayout>
