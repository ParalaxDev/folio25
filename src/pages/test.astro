---
import MainLayout from "../layouts/MainLayout.astro";
import VerticalDivider from "../components/VerticalDivider.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import TestProject from "../components/test/TestProject.astro";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";

import { getCollection } from "astro:content";

const testProject = await getCollection("test");
---

<MainLayout>
    <Header />
    <main class="w-5/6 md:w-3/4 lg:w-1/2 border-x border-border">
        <div class="w-full px-4 py-8 flex justify-between items-center">
            <div>
                <h2 class="text-3xl text-text-primary">Test Project Layout</h2>
                <p class="text-text-secondary">
                    Combining old structure with new styling
                </p>
            </div>
            <div class="hidden md:block">
                <ThemeSwitcher />
            </div>
        </div>
        <VerticalDivider />
        <section id="test-project">
            {
                testProject.map((project) => (
                    <TestProject project={project.data} slug={project.id} />
                ))
            }
        </section>
        <VerticalDivider />
        <Footer />
    </main>
</MainLayout>
