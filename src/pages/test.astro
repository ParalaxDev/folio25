---
import MainLayout from "../layouts/MainLayout.astro";
import VerticalDivider from "../components/VerticalDivider.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import TestProject from "../components/TestProject.astro";

import { getCollection } from "astro:content";

const testProject = await getCollection("projects");
---

<MainLayout>
    <Header />
    <main class="w-5/6 md:w-3/4 lg:w-1/2 border-x border-border">
        <div class="px-4 py-8">
            <a
                href="/#writing"
                class="text-sm text-text-secondary hover:opacity-75 transition-all font-departure-mono flex items-center gap-1"
            >
                <svg
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    class="size-4 inline mr-1"
                >
                    <path
                        d="M20 11v2H8v2H6v-2H4v-2h2V9h2v2h12zM10 7H8v2h2V7zm0 0h2V5h-2v2zm0 10H8v-2h2v2zm0 0h2v2h-2v-2z"
                        fill="currentColor"></path>
                </svg>
                Back to all projects
            </a>
        </div>
        <VerticalDivider />
        <section id="test-project">
            {
                testProject.map((project, i) => {
                    return (
                        <TestProject project={project.data} slug={project.id} />
                    );
                })
            }
        </section>
        <VerticalDivider />
        <Footer />
    </main>
</MainLayout>
